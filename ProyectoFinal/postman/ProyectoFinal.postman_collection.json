{
  "info": {
    "_postman_id": "b0f9e2d4-0000-4f6f-9b7b-123456789abc",
    "name": "ProyectoFinal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection para probar los endpoints de autenticación (crear usuario, login y endpoints protegidos)."
  },
  "item": [
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Juan\",\n  \"surname\": \"Perez\",\n  \"mail\": \"juan@example.com\",\n  \"username\": \"juan\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/users",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "users"
          ]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mail\": \"juan@example.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/users/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "users",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Guarda token y userId en variables de entorno",
              "if (pm.response.code === 200) {",
              "    try {",
              "        var json = pm.response.json();",
              "        if (json.token) { pm.environment.set('jwt', json.token); }",
              "        if (json.user && json.user.id) { pm.environment.set('userId', json.user.id); }",
              "        pm.test('Token guardado', function () { pm.expect(json.token).to.not.be.undefined; });",
              "    } catch (e) { pm.test('Respuesta no JSON', function () { pm.expect.fail('No JSON'); }); }",
              "} else {",
              "    pm.test('Login fallido', function () { pm.expect(pm.response.code).to.equal(200); });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get users (protegido)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/api/users",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "users"
          ]
        }
      }
    }
  ]
}